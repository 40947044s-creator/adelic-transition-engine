
function executeMarilynSnap() {
    isSnapped = true;
    document.getElementById('status').innerText = "GROUNDED_INVARIANT";

    // 1. ANNIHILATE THE OVERLAY: Hide the crawl to reveal the result
    document.getElementById('crawl-stage').style.display = "none";

    // 2. ACTIVATE THE GROUNDED LAW: Force the blog into view
    let blog = document.getElementById('theory-accumulation');
    blog.style.opacity = "1";
    blog.style.visibility = "visible";
    blog.style.zIndex = "9999"; // Absolute priority
    
    // 3. COLLAPSE THE DISTANCE: Auto-scroll to the conclusion
    window.scrollTo({
        top: document.body.scrollHeight,
        behavior: 'smooth'
    });

    MathJax.typeset(); // Final render of the Euler Identity
}
